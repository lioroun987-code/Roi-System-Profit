generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String?    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  accounts      Account[]
  sessions      Session[]
  businesses    Business[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Business {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  description String?

  shopifyDomain        String?
  shopifyApiKey        String?
  shopifyApiSecret     String?
  shopifyAccessToken   String?
  shopifyWebhookSecret String?

  fbAdAccountId String?
  fbAccessToken String?

  googleSheetsId     String?
  googleRefreshToken String? @db.Text
  googleAccessToken  String? @db.Text

  productCosts    Json @default("{}")
  discountRules   Json @default("{}")
  paymentSettings Json @default("{}")
  aiNotes         String? @db.Text


  orders           Order[]
  adSpends         AdSpend[]
  reconcileReports ReconcileReport[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReconcileReport {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  agentSheetId   String
  agentSheetName String?
  ourSheetId     String
  exchangeRate   Float

  results Json
  summary Json
  debug   Json?

  businessUpdatedAt DateTime?
  runAt             DateTime  @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  shopifyOrderId String
  orderNumber    String
  orderDate      DateTime
  customerName   String?
  customerEmail  String?

  rawData    Json
  aiAnalysis Json?

  orderSummary  String?
  paymentMethod String?

  storePrice     Float?
  myCostUsd      Float?
  myCostIls      Float?
  grossProfitIls Float?
  paymentFeeIls  Float?
  vatIls         Float?
  netProfitIls   Float?
  netProfitUsd   Float?
  adSpendAlloc   Float?

  status String @default("pending")

  exportedToSheets Boolean @default(false)
  sheetsRowId      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, shopifyOrderId])
  @@index([businessId, orderDate(sort: Desc)])
}

model AdSpend {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  date        DateTime @db.Date
  spend       Float
  impressions Int?
  clicks      Int?
  reach       Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([businessId, date])
}
